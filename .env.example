# Environment Variables for Email AI Assistant

# Google Gemini API Key (free tier available at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-1.5-flash - free tier)
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-pro
GEMINI_MODEL=gemini-1.5-flash

# Server port (default: 3000)
PORT=3000
