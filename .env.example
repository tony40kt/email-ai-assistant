NODE_ENV=development
APP_BASE_URL=http://localhost:19006
API_BASE_URL=http://localhost:3000

GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
# Expo Go 本機測試用：填入 emailaiassistant://auth/callback
# 部署正式版後改為你的 HTTPS 後端路徑（例如 https://your-api.render.com/api/auth/callback）
GMAIL_REDIRECT_URI=emailaiassistant://auth/callback

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Use your provider's translate endpoint URL (example path: /translate).
LIBRETRANSLATE_API_URL=https://your-libretranslate-host/translate
LIBRETRANSLATE_API_KEY=your_optional_libretranslate_api_key
