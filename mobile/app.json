{
  "expo": {
    "name": "郵件 AI 助手",
    "slug": "email-ai-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emailaiassistant.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "用於保護您的帳號安全"
      }
    },
    "android": {
      "package": "com.emailaiassistant.app"
    },
    "web": {
    },
    "scheme": "emailaiassistant",
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    }
  }
}
